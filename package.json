{
  "name": "bity-smarty",
  "version": "1.0.0",
  "description": "Bity Smarty – a small bot for providing a week diet and grocery list",
  "main": "bin/index.js",
  "type": "module",
  "engines": {
    "node": ">=21.1.0"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest --detectOpenHandles --env-file=.env",
    "lint": "eslint bin",
    "lint:fix": "eslint --fix bin && prettier --write \"bin/**/*.js\"",
    "start": "node --env-file=.env bin/index.js",
    "dev": "nodemon"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vyachowski/bity-smarty.git"
  },
  "keywords": [
    "bot",
    "diet",
    "healthy"
  ],
  "author": "Slava Haikin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vyachowski/bity-smarty/issues"
  },
  "homepage": "https://github.com/Vyachowski/bity-smarty#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^2.1.2",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-perfectionist": "^2.2.0",
    "nodemon": "^3.0.1",
    "prettier": "3.0.3"
  },
  "dependencies": {
    "mongodb": "6.2",
    "mongoose": "^7.6.3",
    "node-telegram-bot-api": "^0.64.0"
  }
}
